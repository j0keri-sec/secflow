# ================================================
# SecFlow 环境配置示例
# 复制此文件为 .env 并修改相应配置
# ================================================

# ─────────────────────────────────────────────
# 网络配置 (macvlan 模式)
# ─────────────────────────────────────────────
SECFLOW_NETWORK=pub_net
SECFLOW_NETWORK_SUBNET=172.16.100.0/24
SECFLOW_NETWORK_GATEWAY=172.16.100.254

# ─────────────────────────────────────────────
# MongoDB 配置
# ─────────────────────────────────────────────
MONGO_ROOT_USER=secflow
MONGO_ROOT_PASS=secflow_pass_secure_2026
MONGO_DATABASE=secflow

# ─────────────────────────────────────────────
# Redis 配置
# ─────────────────────────────────────────────
REDIS_PASSWORD=redis_pass_secure_2026

# ─────────────────────────────────────────────
# JWT & 安全配置
# ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
NODE_TOKEN_KEY=your-node-token-key-change-this

# ─────────────────────────────────────────────
# 服务端配置
# ─────────────────────────────────────────────
SECFLOW_ENV=production
SECFLOW_PORT=8989
SECFLOW_LOG_LEVEL=info

# ─────────────────────────────────────────────
# Grafana 配置
# ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASS=admin123
GRAFANA_URL=http://localhost:3000

# ─────────────────────────────────────────────
# 客户端节点配置 (多节点部署时使用)
# ─────────────────────────────────────────────
CLIENT_TOKEN_BEIJING=client-beijing-token
CLIENT_TOKEN_SHANGHAI=client-shanghai-token
CLIENT_TOKEN_GUANGZHOU=client-guangzhou-token

# ─────────────────────────────────────────────
# 推送通知配置 (可选)
# ─────────────────────────────────────────────
DINGTALK_WEBHOOK=
FEISHU_WEBHOOK=

# ─────────────────────────────────────────────
# 数据保留配置
# ─────────────────────────────────────────────
DATA_RETENTION_DAYS=90
