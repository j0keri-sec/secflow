# SecFlow Client Configuration
# Copy this file to client.yaml and modify as needed

# Node identification
node_id: ""  # Leave empty to auto-generate
name: "my-node"  # Display name for this node

# Operating mode: "server" or "standalone"
mode: "server"

# Server connection (for server mode)
server:
  api_url: "http://localhost:8080/api/v1"
  ws_url: "ws://localhost:8080/api/v1/ws/node"
  token_key: "your-shared-node-token"  # Must match server's NODE_TOKEN_KEY

# Grabber sources to enable (empty = all available)
# Available sources:
#   - avd-rod, seebug-rod, ti-rod, nox-rod
#   - kev-rod, struts2-rod, chaitin-rod
#   - oscs-rod, threatbook-rod, venustech-rod
sources: []

# Proxy configuration (optional)
# proxy: "http://proxy.example.com:8080"

# Heartbeat interval
heartbeat_interval: "30s"

# Logging
log_level: "info"  # debug, info, warn, error
log_path: ""       # Empty = stdout only

# Database (local SQLite for standalone mode and caching)
db_path: "./secflow.db"
