# ================================================
# SecFlow Client Test Dockerfile
# Optimized for running tests in Docker
# ================================================
FROM golang:1.23-bookworm AS builder

# Set Go proxy for China accessibility
ENV GOPROXY=https://goproxy.cn,direct
ENV GOSUMDB=off

# Install build dependencies and Chromium
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates chromium chromium-driver && rm -rf /var/lib/apt/lists/*

# Set Chrome environment variables
ENV CHROME_BIN=/usr/bin/chromium
ENV CHROMEDRIVER_PATH=/usr/bin/chromedriver

WORKDIR /build

# Copy go mod files first for better caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build the client
RUN CGO_ENABLED=0 GOOS=linux go build -o client-test ./cmd/client/

# ================================================
# Test runner image
# ================================================
FROM debian:bookworm-slim

# Install test dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl wget ca-certificates chromium chromium-driver && rm -rf /var/lib/apt/lists/*

# Set Chrome environment variables
ENV CHROME_BIN=/usr/bin/chromium
ENV CHROMEDRIVER_PATH=/usr/bin/chromedriver
ENV SECFLOW_HEADLESS=true

# Copy test binaries from builder
COPY --from=builder /build/client-test /usr/local/bin/

# Copy test scripts
COPY --from=builder /build/tests /tests

WORKDIR /app

# Default command runs tests
CMD ["sh"]
