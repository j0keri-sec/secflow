# =============================================================================
# SecFlow .dockerignore
# 
# 优化 Docker 镜像构建，排除不必要的文件
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# 文档 (不需要在镜像中)
*.md
docs/
LICENSE
CHANGELOG.md
TODO.md

# 测试文件
**/*_test.go
**/test_*.go
**/tests/
test/
*.test
*.out
coverage.out

# 开发文件
.env
.env.*
!.env.example
.claude/
.workbuddy/
.vscode/
.idea/
*.swp
*.swo
*~

# 前端构建产物 (如果有独立构建)
# secflow-web/dist/  # 如果是独立构建的
secflow-web/node_modules/

# 日志和临时文件
*.log
logs/
tmp/
temp/
*.tmp

# 本地配置文件
config/config.yaml
config/*.local.*

# 其他开发文件
scripts/test_*
*.bak
*.backup
.DS_Store
Thumbs.db

# 监控配置 (可选，如果不需要在运行时)
monitoring/

# 客户端 (如果不需要在服务端镜像中)
secflow-client/

# Workload identity 文件 (不应该在镜像中)
*.key
*.pem
credentials/
secrets/

# 构建缓存 (会被忽略但明确列出)
vendor/
node_modules/
vendor/github.com/
vendor/golang.org/
vendor/go.mongodb.org/

# 文档和脚本 (如果不需要在运行时)
# 注意: 如果你的 Dockerfile 需要这些，请注释掉对应行
docs/
scripts/
monitoring/
*.md
